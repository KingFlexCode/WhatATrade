# ============================================================
#  TraderPulse Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it contains secrets.
# ============================================================

# --- Server ---
PORT=3001
NODE_ENV=development

# Session secret — change this to any long random string
SESSION_SECRET=239847987834koeorikit009234984klwill--erekj23

# --- Your frontend URL (for CORS and OAuth redirects) ---
FRONTEND_URL=http://localhost:3000

# ============================================================
#  THINKORSWIM / SCHWAB
#  Get these from: https://developer.schwab.com
#  1. Create a free account
#  2. Register a new app
#  3. Set redirect URI to: http://localhost:3001/auth/schwab/callback
#  4. Copy Client ID and Client Secret below
# ============================================================
SCHWAB_CLIENT_ID=YOUR_SCHWAB_CLIENT_ID_HERE
SCHWAB_CLIENT_SECRET=YOUR_SCHWAB_CLIENT_SECRET_HERE
SCHWAB_REDIRECT_URI=http://localhost:3001/auth/schwab/callback

# ============================================================
#  WEBULL
#  Get these from: https://developer.webull.com
#  1. Create a free account
#  2. Register app under the "Connect API" tier
#  3. Set redirect URI to: http://localhost:3001/auth/webull/callback
#  4. Copy App Key and App Secret below
# ============================================================
WEBULL_APP_KEY=YOUR_WEBULL_APP_KEY_HERE
WEBULL_APP_SECRET=YOUR_WEBULL_APP_SECRET_HERE
WEBULL_REDIRECT_URI=http://localhost:3001/auth/webull/callback
